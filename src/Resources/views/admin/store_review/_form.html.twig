{{ sylius_template_event('setono_sylius_review.admin.store_review.update.javascripts') }}

<div class="ui stackable grid">
    <div class="twelve wide column">
        <div class="ui segment">
            {{ form_errors(form) }}
            {{ form_row(form.title) }}
            {{ form_row(form.comment) }}
            {{ form_row(form.rating) }}
            {{ form_row(form.storeReply) }}
        </div>
    </div>
    <div class="four wide column">
        {% include '@SetonoSyliusReviewPlugin/admin/store_review/_channel.html.twig' %}
        {% include '@SetonoSyliusReviewPlugin/admin/store_review/_author.html.twig' %}
    </div>
</div>
