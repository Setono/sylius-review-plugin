{% block setono_sylius_review_markdown_textarea_widget %}
    <style>
        markdown-toolbar:not(:defined) { display: none; }
        .markdown-textarea-container .markdown-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 1px solid rgba(34,36,38,.15);
            border-bottom: none;
            border-radius: .28571429rem .28571429rem 0 0;
            background: #f6f8fa;
            padding: 4px 8px;
        }
        .markdown-textarea-container .markdown-header .ui.secondary.pointing.menu {
            margin-bottom: 0;
            border-bottom: none;
            min-height: auto;
        }
        .markdown-textarea-container .markdown-header .ui.secondary.pointing.menu .item {
            padding: 6px 12px;
        }
        .markdown-textarea-container .markdown-header markdown-toolbar {
            display: flex;
            align-items: center;
            gap: 2px;
        }
        .markdown-textarea-container .markdown-header markdown-toolbar .ui.icon.buttons {
            margin: 0;
        }
        .markdown-textarea-container textarea {
            border-top-left-radius: 0 !important;
            border-top-right-radius: 0 !important;
        }
        .markdown-textarea-container .markdown-preview {
            min-height: 120px;
            padding: 10px;
            border: 1px solid rgba(34,36,38,.15);
            border-top: none;
            border-radius: 0 0 .28571429rem .28571429rem;
            background: #fff;
            overflow-y: auto;
        }
        .markdown-textarea-container .markdown-preview:empty::before {
            content: 'Nothing to preview';
            color: rgba(0,0,0,.4);
            font-style: italic;
        }
    </style>
    <div class="markdown-textarea-container" data-textarea-id="{{ id }}">
        <div class="markdown-header">
            <div class="ui secondary pointing menu">
                <a class="item active" data-tab="write">{{ 'setono_sylius_review.ui.write'|trans }}</a>
                <a class="item" data-tab="preview">{{ 'setono_sylius_review.ui.preview'|trans }}</a>
            </div>
            <markdown-toolbar for="{{ id }}">
                <div class="ui icon buttons mini">
                    <md-header class="ui button" title="Heading"><i class="heading icon"></i></md-header>
                    <md-bold class="ui button" title="Bold"><i class="bold icon"></i></md-bold>
                    <md-italic class="ui button" title="Italic"><i class="italic icon"></i></md-italic>
                    <md-quote class="ui button" title="Quote"><i class="quote left icon"></i></md-quote>
                    <md-code class="ui button" title="Code"><i class="code icon"></i></md-code>
                    <md-link class="ui button" title="Link"><i class="linkify icon"></i></md-link>
                </div>
                <div class="ui icon buttons mini">
                    <md-unordered-list class="ui button" title="Bulleted list"><i class="list ul icon"></i></md-unordered-list>
                    <md-ordered-list class="ui button" title="Numbered list"><i class="list ol icon"></i></md-ordered-list>
                </div>
            </markdown-toolbar>
        </div>
        <div data-tab-content="write">
            {{ block('textarea_widget') }}
        </div>
        <div data-tab-content="preview" class="markdown-preview" style="display: none;"></div>
    </div>
{% endblock %}
