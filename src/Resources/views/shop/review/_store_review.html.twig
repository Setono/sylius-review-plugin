<div style="margin-bottom: 3rem;">
    <h3>{{ 'setono_sylius_review.ui.store_review'|trans }}</h3>
    <p style="color: #666; margin-bottom: 1.5rem;">{{ 'setono_sylius_review.ui.store_review_description'|trans }}</p>

    <div class="field">
        {{ form_label(form.storeReview.rating) }}
        <div class="ui huge star rating" data-rating="{{ form.storeReview.rating.vars.data ?? 0 }}" data-max-rating="5" data-rating-target="{{ form.storeReview.rating.vars.id }}"><i class="icon"></i><i class="icon"></i><i class="icon"></i><i class="icon"></i><i class="icon"></i></div>
        <div id="{{ form.storeReview.rating.vars.id }}" style="display: none">
            {{ form_widget(form.storeReview.rating) }}
        </div>
        {{ form_errors(form.storeReview.rating) }}
    </div>
    {{ form_row(form.storeReview.comment) }}
</div>
