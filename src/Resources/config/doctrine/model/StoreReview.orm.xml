<?xml version="1.0" encoding="UTF-8"?>

<doctrine-mapping xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <mapped-superclass name="Setono\SyliusReviewPlugin\Model\StoreReview"
                       table="setono_sylius_review__store_review">
        <id name="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="rating" type="integer" nullable="true"/>
        <field name="comment" type="text" nullable="true"/>
        <field name="state" type="string"/>
        <field name="authorEmail" column="author_email" type="string" nullable="true"/>
        <field name="authorFirstName" column="author_first_name" type="string" nullable="true"/>
        <field name="authorLastName" column="author_last_name" type="string" nullable="true"/>
        <field name="authorCity" column="author_city" type="string" nullable="true"/>
        <field name="authorCountry" column="author_country" type="string" nullable="true"/>
        <field name="createdAt" column="created_at" type="datetime"/>
        <field name="updatedAt" column="updated_at" type="datetime" nullable="true"/>

        <many-to-one field="order" target-entity="Sylius\Component\Order\Model\OrderInterface">
            <join-column name="order_id" referenced-column-name="id" on-delete="SET NULL" nullable="true"/>
        </many-to-one>

        <one-to-one field="review" target-entity="Setono\SyliusReviewPlugin\Model\ReviewInterface"
                    mapped-by="storeReview">
        </one-to-one>

        <indexes>
            <index columns="state"/>
            <index columns="created_at"/>
        </indexes>
    </mapped-superclass>
</doctrine-mapping>
