<?xml version="1.0" encoding="UTF-8"?>

<doctrine-mapping xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <mapped-superclass name="Setono\SyliusReviewPlugin\Model\Review"
                       table="setono_sylius_review__review">
        <id name="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="createdAt" column="created_at" type="datetime"/>
        <field name="updatedAt" column="updated_at" type="datetime" nullable="true"/>

        <many-to-one field="order" target-entity="Sylius\Component\Order\Model\OrderInterface">
            <join-column name="order_id" referenced-column-name="id" on-delete="CASCADE" nullable="false"/>
        </many-to-one>

        <one-to-one field="storeReview" target-entity="Setono\SyliusReviewPlugin\Model\StoreReviewInterface"
                    inversed-by="review">
            <join-column name="store_review_id" referenced-column-name="id" on-delete="SET NULL" nullable="true"/>
            <cascade>
                <cascade-persist/>
            </cascade>
        </one-to-one>

        <one-to-many field="productReviews" target-entity="Setono\SyliusReviewPlugin\Model\ProductReviewInterface"
                     mapped-by="review">
            <cascade>
                <cascade-persist/>
            </cascade>
        </one-to-many>
    </mapped-superclass>
</doctrine-mapping>
